{
  "name": "revis-cli",
  "version": "0.1.0",
  "description": "Passive distributed workspace coordination for coding agents",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mu-hashmi/revis.git"
  },
  "bugs": {
    "url": "https://github.com/mu-hashmi/revis/issues"
  },
  "homepage": "https://github.com/mu-hashmi/revis#readme",
  "keywords": [
    "cli",
    "coordination",
    "distributed",
    "git",
    "multi-agent",
    "passive",
    "research",
    "tmux"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "revis": "dist/bin/revis.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown && chmod +x dist/bin/revis.js",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsdown": "^0.4.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
