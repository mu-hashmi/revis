{
  "name": "revis-cli",
  "version": "0.1.1",
  "description": "Passive distributed workspace coordination for coding agents",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mu-hashmi/revis.git"
  },
  "bugs": {
    "url": "https://github.com/mu-hashmi/revis/issues"
  },
  "homepage": "https://github.com/mu-hashmi/revis#readme",
  "keywords": [
    "cli",
    "coordination",
    "distributed",
    "git",
    "multi-agent",
    "passive",
    "research",
    "headless"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "revis": "dist/bin/revis.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:cli && npm run build:dashboard && chmod +x dist/bin/revis.js",
    "build:cli": "tsdown",
    "build:dashboard": "node ./scripts/build-dashboard.mjs",
    "prepare": "effect-language-service patch",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@daytonaio/sdk": "^0.151.0",
    "@effect/cli": "^0.72.1",
    "@effect/platform": "^0.93.3",
    "@effect/platform-node": "^0.93.0",
    "@effect/printer": "^0.47.0",
    "@effect/printer-ansi": "^0.47.0",
    "effect": "^3.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@effect/language-service": "^0.80.0",
    "@effect/vitest": "^0.28.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "effect-solutions": "^0.4.13",
    "esbuild": "^0.27.4",
    "tsdown": "^0.4.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
