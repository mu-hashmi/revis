{
  "name": "revis-cli",
  "version": "0.1.1",
  "description": "Passive distributed workspace coordination for coding agents",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mu-hashmi/revis.git"
  },
  "bugs": {
    "url": "https://github.com/mu-hashmi/revis/issues"
  },
  "homepage": "https://github.com/mu-hashmi/revis#readme",
  "keywords": [
    "cli",
    "coordination",
    "distributed",
    "git",
    "multi-agent",
    "passive",
    "research",
    "headless"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "revis": "dist/bin/revis.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:cli && chmod +x dist/bin/revis.js",
    "build:cli": "tsdown",
    "prepare": "effect-language-service patch",
    "prepublishOnly": "npm run typecheck && npm run build",
    "test": "vitest run --passWithNoTests",
    "test:acceptance": "npm run build && vitest run --passWithNoTests",
    "test:all": "npm test && npm run test:acceptance",
    "test:contracts": "vitest run --passWithNoTests",
    "test:transport": "vitest run --passWithNoTests",
    "test:orchestration": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@daytonaio/sdk": "^0.151.0",
    "@e2b/code-interpreter": "^2.3.3",
    "@effect/platform": "^0.95.0",
    "@effect/platform-node": "^0.105.0",
    "dockerode": "^4.0.9",
    "effect": "^3.20.0",
    "get-port": "^7.1.0",
    "sandbox-agent": "^0.5.0-rc.1"
  },
  "devDependencies": {
    "@effect/language-service": "^0.80.0",
    "@types/node": "^25.5.0",
    "tsdown": "^0.4.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
